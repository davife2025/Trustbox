{
  "name": "trustboxhedera-ai",
  "version": "1.0.0",
  "private": true,
  "description": "TrustBox Hedera AI \u2014 Verifiable trust infrastructure for AI agents on Hedera",
  "workspaces": [
    "packages/shared",
    "packages/contracts",
    "packages/backend",
    "packages/frontend"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "build:shared": "npm run build --workspace=packages/shared",
    "build:contracts": "npm run build --workspace=packages/contracts",
    "build:backend": "npm run build --workspace=packages/backend",
    "build:frontend": "npm run build --workspace=packages/frontend",
    "dev:backend": "npm run dev --workspace=packages/backend",
    "dev:frontend": "npm run dev --workspace=packages/frontend",
    "deploy:contracts": "npm run deploy --workspace=packages/contracts",
    "test:contracts": "npm run test --workspace=packages/contracts",
    "lint": "npm run lint --workspaces --if-present",
    "clean": "rm -rf packages/*/dist packages/*/node_modules node_modules"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "overrides": {
    "rollup": "3.29.4"
  }
}