###############################################################################
## TrustBoxHedera AI — Environment Variables
## Copy to .env and fill in values. Never commit .env.
###############################################################################

# ── Hedera Operator ──────────────────────────────────────────────────────────
          # testnet | mainnet

# ── Hedera HCS Topic IDs (created by scripts/createTopics.ts) ───────────────
HCS_CREDIT_TOPIC_ID=0.0.XXXXXX
HCS_AUDIT_TOPIC_ID=0.0.XXXXXX
HCS_INTENT_TOPIC_ID=0.0.XXXXXX
HCS_AGENT_TOPIC_ID=0.0.XXXXXX
HCS_BLINDAUDIT_TOPIC_ID=0.0.XXXXXX

# ── Hedera HTS Token IDs (created by scripts/createTokens.ts) ───────────────
HTS_CREDENTIAL_TOKEN_ID=0.0.XXXXXX  # ERC-8004 credential NFT series

# ── HSCS Contract Addresses (filled after deploy) ────────────────────────────
TRUST_REGISTRY_ADDR=0x...
AUDIT_REGISTRY_ADDR=0x...
AGENT_MARKETPLACE_ADDR=0x...
INTENT_VAULT_ADDR=0x...

# ── Hashio RPC (Hedera EVM) ──────────────────────────────────────────────────
HEDERA_RPC_URL=https://testnet.hashio.io/api
HEDERA_CHAIN_ID=296                  # 296 testnet | 295 mainnet

# ── Deployer wallet ──────────────────────────────────────────────────────────
DEPLOYER_PRIVATE_KEY=0x...           # EVM private key for HSCS deploys

# ── Backend ──────────────────────────────────────────────────────────────────
PORT=4000
JWT_SECRET=change_this_to_a_long_random_string
NODE_ENV=development

# ── Groq (AI intent parsing + contract audit) ────────────────────────────────
GROQ_API_KEY=gsk_...

# ── Pinata IPFS ──────────────────────────────────────────────────────────────
PINATA_JWT=eyJ...
PINATA_GATEWAY=https://gateway.pinata.cloud

# ── Pyth Price Feeds (Hedera-native oracle) ──────────────────────────────────
PYTH_CONTRACT_ADDRESS=0x...          # Pyth contract on HSCS testnet
# Price feed IDs (from https://pyth.network/developers/price-feed-ids)
PYTH_HBAR_USD_FEED=0x...
PYTH_ETH_USD_FEED=0x...
PYTH_BTC_USD_FEED=0x...

# ── Phala TEE ────────────────────────────────────────────────────────────────
PHALA_ENDPOINT=https://api.phala.network/api/contract/dispatch
PHALA_AGENT_CONTRACT=0x...

# ── HashConnect (Option B wallet — frontend only) ────────────────────────────
VITE_HASHCONNECT_PROJECT_ID=your_walletconnect_project_id
VITE_APP_NAME=TrustBox Hedera AI

# ── Frontend ─────────────────────────────────────────────────────────────────
VITE_BACKEND_URL=http://localhost:4000
VITE_HEDERA_NETWORK=testnet
VITE_HEDERA_CHAIN_ID=296
